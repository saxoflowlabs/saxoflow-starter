# Ensure shell scripts always use LF line endings regardless of OS
*.sh        text eol=lf

# Python and text files: normalise to LF in the repo
*.py        text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf

# Binary files: no line-ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.pdf       binary
*.zip       binary
*.gz        binary
